// Tree-related stuff

// Tree types
// ----------

// type BinTree[D] =
//  | Node {left: BinTree, right: BinTree, data: D}
//  | Leaf {data: D}

type ClockTree = 
    | Node {left: ClockTree, right: ClockTree, age: Real}
    | Leaf {age: Real}


// Tree functions
// --------------
function countLeaves(tree: ClockTree) => Int {
  if tree is Node {
    return countLeaves(tree.left) + countLeaves(tree.right);
  }
  return 1;
}

